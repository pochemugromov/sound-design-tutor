# Copy this file to .env and put your real key only there.
# .env is ignored by Git and must not be committed.
GEMINI_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
CHAT_MODEL=gemini-3-flash-preview
EMBEDDING_MODEL=gemini-embedding-001
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_TRACING_ENVIRONMENT=development
LANGFUSE_SAMPLE_RATE=1
LANGFUSE_CAPTURE_IO=true
LANGFUSE_FLUSH_ON_REQUEST_END=false
LANGFUSE_MAX_FIELD_CHARS=12000
APP_HOST=127.0.0.1
APP_PORT=8000
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.35
RAG_MAX_CHUNKS_PER_SOURCE=24
DATABASE_PATH=data/app.db
CHROMA_PATH=data/chroma

# Cloud deployment (uncomment for Vercel/production)
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
